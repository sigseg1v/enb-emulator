<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="ToolsPatcherAvalonia.MainWindow"
        Width="573" Height="363"
        Title="E&amp;B Tools Patcher"
        CanResize="False">
  <Grid Margin="12" RowDefinitions="Auto,Auto,Auto,Auto,Auto,*">
    <!-- Row 0: server/client version (left) -->
    <StackPanel Grid.Row="0" HorizontalAlignment="Left">
      <TextBlock Name="VerLabel"    Text="Server Version: " />
      <TextBlock Name="ClientVer"   Text="Client Version: " />
    </StackPanel>

    <!-- Row 1: file label -->
    <TextBlock Grid.Row="1" Name="CFileName" Margin="0,12,0,0" Text="File Downloading:" />

    <!-- Row 2: file progress bar + percent -->
    <Grid Grid.Row="2" ColumnDefinitions="*,Auto" Margin="0,4,0,0">
      <ProgressBar Grid.Column="0" Name="FileProgress" Height="20" Minimum="0" Maximum="100" />
      <TextBlock   Grid.Column="1" Name="ProgressValue" Margin="8,0,0,0" Text="0%" />
    </Grid>

    <!-- Row 3: total progress label -->
    <TextBlock Grid.Row="3" Name="label2" Margin="0,8,0,0" Text="Total Progress:" />

    <!-- Row 4: total progress bar + percent -->
    <Grid Grid.Row="4" ColumnDefinitions="*,Auto" Margin="0,4,0,0">
      <ProgressBar Grid.Column="0" Name="TotalProgress" Height="20" Minimum="0" Maximum="100" />
      <TextBlock   Grid.Column="1" Name="TotalProgressValue" Margin="8,0,0,0" Text="0%" />
    </Grid>

    <!-- Row 5: patch-notes pane. The original WinForms loaded
         http://toolspatch.net-7.org/PatchNotes.html in a WebBrowser
         control. The host is long-dead and Avalonia has no built-in
         WebView, so we drop a placeholder TextBox here. A future
         Avalonia.WebView integration could swap this in. -->
    <TextBox Grid.Row="5" Name="PatchNotes"
             Margin="0,12,0,0"
             IsReadOnly="True"
             AcceptsReturn="True"
             TextWrapping="Wrap"
             Text="Patch notes panel (legacy WebBrowser was http://toolspatch.net-7.org/PatchNotes.html — host is gone)" />
  </Grid>
</Window>
