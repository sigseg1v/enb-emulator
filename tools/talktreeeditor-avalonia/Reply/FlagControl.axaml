<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="28"
             x:Class="TalkTreeEditorAvalonia.Reply.FlagControl">
  <StackPanel Orientation="Horizontal" Spacing="4">
    <ComboBox x:Name="c_TypeCbo"  Width="180" SelectionChanged="OnTypeSelected" />
    <TextBox  x:Name="c_ValueTxt" Width="160" TextChanged="OnValueTextChanged" />
    <ComboBox x:Name="c_ValueCbo" Width="160" IsVisible="False" SelectionChanged="OnValueSelected" />
  </StackPanel>
</UserControl>
