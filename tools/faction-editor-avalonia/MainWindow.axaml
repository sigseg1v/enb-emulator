<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="using:FactionEditorAvalonia"
        x:Class="FactionEditorAvalonia.MainWindow"
        Width="720" Height="600"
        Title="Faction Editor"
        WindowStartupLocation="CenterScreen">
  <DockPanel>

    <!-- Menu bar -->
    <Menu DockPanel.Dock="Top">
      <MenuItem Header="_File">
        <MenuItem Header="_New"    Click="OnNewClick" />
        <MenuItem Header="_Save"   Click="OnSaveClick" />
        <MenuItem Header="_Delete" Click="OnDeleteClick" />
        <Separator />
        <MenuItem Header="E_xit"   Click="OnExitClick" />
      </MenuItem>
      <MenuItem Header="_Edit">
        <MenuItem Header="_Refresh Table" Click="OnRefreshClick" />
      </MenuItem>
      <MenuItem Header="_Help">
        <MenuItem Header="_About" Click="OnAboutClick" />
      </MenuItem>
    </Menu>

    <!-- Toolbar -->
    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="4,4,4,0" Spacing="4">
      <Button Content="New"     Click="OnNewClick"     ToolTip.Tip="New Faction" />
      <Button Content="Save"    Click="OnSaveClick"    ToolTip.Tip="Save Current Faction" />
      <Button Content="Delete"  Click="OnDeleteClick"  ToolTip.Tip="Delete Selected Faction" />
      <Border Width="1" Background="Gray" Margin="6,0" />
      <Button Content="Refresh" Click="OnRefreshClick" ToolTip.Tip="Refresh Faction Table" />
    </StackPanel>

    <!-- Status bar -->
    <Border DockPanel.Dock="Bottom" BorderBrush="Gray" BorderThickness="0,1,0,0" Padding="6,2">
      <TextBlock Name="c_Status" Text="Ready" />
    </Border>

    <!-- Body: top tabs (General/Matrix), bottom faction list -->
    <Grid RowDefinitions="*,4,*">
      <TabControl Grid.Row="0" Margin="4">
        <TabItem Header="General Details">
          <Grid Margin="8" ColumnDefinitions="120,*" RowDefinitions="Auto,Auto,*">
            <TextBlock Grid.Row="0" Grid.Column="0" Text="Name:"        VerticalAlignment="Center" Margin="0,4" />
            <TextBox   Grid.Row="0" Grid.Column="1" Name="c_NameText"   Margin="0,4" />

            <TextBlock Grid.Row="1" Grid.Column="0" Text="PDA Text:"    VerticalAlignment="Center" Margin="0,4" />
            <TextBox   Grid.Row="1" Grid.Column="1" Name="c_PdaText"    Margin="0,4" />

            <TextBlock Grid.Row="2" Grid.Column="0" Text="Description:" VerticalAlignment="Top"    Margin="0,4" />
            <TextBox   Grid.Row="2" Grid.Column="1" Name="c_DescriptionText"
                       AcceptsReturn="True" TextWrapping="Wrap"
                       VerticalAlignment="Stretch" Margin="0,4" />
          </Grid>
        </TabItem>

        <TabItem Header="Faction Matrix">
          <Grid Margin="8" ColumnDefinitions="*,8,*">
            <DockPanel Grid.Column="0">
              <TextBlock DockPanel.Dock="Top" Text="Available Factions:" Margin="0,0,0,4" />
              <ListBox Name="c_FactionList" SelectionChanged="OnFactionListSelectionChanged" />
            </DockPanel>

            <DockPanel Grid.Column="2">
              <TextBlock DockPanel.Dock="Top" Text="Faction Properties:" Margin="0,0,0,4" />
              <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto">
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Base Value:"     VerticalAlignment="Center" Margin="0,4,8,4"
                           ToolTip.Tip="The base like/dislike value for this faction. + and - allowed." />
                <NumericUpDown Grid.Row="0" Grid.Column="1" Name="c_BaseValue"
                               FormatString="0"
                               Minimum="-32768" Maximum="32767" Value="0"
                               ValueChanged="OnBaseValueChanged"
                               Margin="0,4" />

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Current Value:"  VerticalAlignment="Center" Margin="0,4,8,4"
                           ToolTip.Tip="The current like/dislike value of the faction in the live server (read-only)." />
                <TextBox       Grid.Row="1" Grid.Column="1" Name="c_CurrentValue"
                               IsReadOnly="True" Margin="0,4" />

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Reward Faction:" VerticalAlignment="Center" Margin="0,4,8,4"
                           ToolTip.Tip="Increases or decreases if you kill the root faction. True for increase, False for decrease." />
                <CheckBox      Grid.Row="2" Grid.Column="1" Name="c_RewardFaction"
                               IsCheckedChanged="OnRewardFactionChanged" Margin="0,4" />
              </Grid>
            </DockPanel>
          </Grid>
        </TabItem>
      </TabControl>

      <GridSplitter Grid.Row="1" ResizeDirection="Rows" HorizontalAlignment="Stretch" Background="Gray" />

      <DataGrid Grid.Row="2" Name="c_FactionGrid" Margin="4"
                x:DataType="local:FactionRow"
                IsReadOnly="True" CanUserResizeColumns="True"
                GridLinesVisibility="All"
                SelectionMode="Single"
                SelectionChanged="OnFactionGridSelectionChanged">
        <DataGrid.Columns>
          <DataGridTextColumn Header="Faction ID" Binding="{Binding FactionID}" Width="100" />
          <DataGridTextColumn Header="Name"       Binding="{Binding Name}"      Width="*" />
        </DataGrid.Columns>
      </DataGrid>
    </Grid>

  </DockPanel>
</Window>
