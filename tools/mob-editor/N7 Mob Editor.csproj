<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <RootNamespace>N7</RootNamespace>
    <AssemblyName>N7 Mob Editor</AssemblyName>
    <UseWindowsForms>true</UseWindowsForms>
    <Nullable>disable</Nullable>
    <LangVersion>latest</LangVersion>
    <ImplicitUsings>disable</ImplicitUsings>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <NoWarn>CS0108;CS0114;CS0414;CS0219;CS0162;CS0168;CS0169;CS0612;CS0618;CS0628;CS1591;CS8981;CS0436;NU1701;MSB3277</NoWarn>
  </PropertyGroup>
  <ItemGroup>
    <Reference Include="LaMarvin.Windows.Forms.ColorPicker">
      <HintPath>..\commontools\Libs\release\LaMarvin.Windows.Forms.ColorPicker.dll</HintPath>
    </Reference>
    <PackageReference Include="MySql.Data" Version="9.4.0" />
  </ItemGroup>
  <ItemGroup>
    <EmbeddedResource Update="GUI\AboutBox.resx">
      <DependentUpon>AboutBox.cs</DependentUpon>
    </EmbeddedResource>
    <EmbeddedResource Update="GUI\ItemBaseAssets.resx">
      <DependentUpon>ItemBaseAssets.cs</DependentUpon>
    </EmbeddedResource>
    <EmbeddedResource Update="GUI\MobBaseAssets.resx">
      <DependentUpon>MobBaseAssets.cs</DependentUpon>
    </EmbeddedResource>
    <EmbeddedResource Update="GUI\Login.resx">
      <DependentUpon>Login.cs</DependentUpon>
    </EmbeddedResource>
    <EmbeddedResource Update="GUI\mainFrm.resx">
      <DependentUpon>mainFrm.cs</DependentUpon>
    </EmbeddedResource>
  </ItemGroup>
  <ItemGroup>
    <Content Include="EB.ICO" />
    <Content Include="lib\LaMarvin.Windows.Forms.ColorPicker.dll" />
    <Content Include="MySql.Data.dll" />
  </ItemGroup>
</Project>
