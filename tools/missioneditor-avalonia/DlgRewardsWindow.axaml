<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="MissionEditorAvalonia.DlgRewardsWindow"
        Width="500" Height="260"
        WindowStartupLocation="CenterOwner"
        Title="Reward">
  <Grid RowDefinitions="Auto,Auto,Auto,Auto,*,Auto" ColumnDefinitions="120,*,Auto" Margin="10">

    <TextBlock Grid.Row="0" Grid.Column="0" Text="Type:" VerticalAlignment="Center"/>
    <ComboBox  Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2" Name="c_TypeCbo" Margin="6,2"/>

    <TextBlock Grid.Row="1" Grid.Column="0" Text="Code:" VerticalAlignment="Center"/>
    <TextBox   Grid.Row="1" Grid.Column="1" Name="c_CodeTxt" Margin="6,2" IsEnabled="False"/>
    <Button    Grid.Row="1" Grid.Column="2" Name="c_CodeSearchBtn" Content="Search..." Margin="2" IsEnabled="False" Click="OnCodeSearch"/>

    <TextBlock Grid.Row="2" Grid.Column="0" Text="Description:" VerticalAlignment="Center"/>
    <TextBox   Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" Name="c_CodeDescriptionTxt" IsReadOnly="True" Margin="6,2"/>

    <TextBlock Grid.Row="3" Grid.Column="0" Text="Amount:" VerticalAlignment="Center"/>
    <TextBox   Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2" Name="c_AmountTxt" Margin="6,2" IsEnabled="False"/>

    <StackPanel Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="3" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="6">
      <Button Content="OK"     Name="c_OkBtn"     Click="OnOk"/>
      <Button Content="Cancel" Name="c_CancelBtn" Click="OnCancel"/>
    </StackPanel>

  </Grid>
</Window>
