<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="LaunchNet7Avalonia.App"
             RequestedThemeVariant="Light">

  <Application.Styles>
    <!-- enb-theme: purple accent (#5d00cf), off-white light region
         (#f9ffff), charcoal dark region (#333230). Source palette:
         ~/Documents/enb-theme. FluentTheme.Palettes.ColorPaletteResources
         is the supported override hook in Avalonia 11.x — it cascades
         the Accent into AccentFillColorDefault et al., and RegionColor
         into SystemRegionColor / window chrome. -->
    <FluentTheme>
      <FluentTheme.Palettes>
        <ColorPaletteResources x:Key="Light"
                               Accent="#5d00cf"
                               RegionColor="#f9ffff" />
        <ColorPaletteResources x:Key="Dark"
                               Accent="#5d00cf"
                               RegionColor="#333230" />
      </FluentTheme.Palettes>
    </FluentTheme>
  </Application.Styles>

  <Application.Resources>
    <ResourceDictionary>
      <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Light">
          <SolidColorBrush x:Key="SystemRegionBrush" Color="#f9ffff" />
        </ResourceDictionary>
        <ResourceDictionary x:Key="Dark">
          <SolidColorBrush x:Key="SystemRegionBrush" Color="#333230" />
        </ResourceDictionary>
      </ResourceDictionary.ThemeDictionaries>
    </ResourceDictionary>
  </Application.Resources>
</Application>
