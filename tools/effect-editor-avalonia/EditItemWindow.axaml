<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="680" d:DesignHeight="560"
        x:Class="EffectEditorAvalonia.EditItemWindow"
        Title="Edit Items" Width="680" Height="580"
        WindowStartupLocation="CenterOwner">
  <ScrollViewer>
  <StackPanel Margin="8" Spacing="6">

    <HeaderedContentControl Header="Item" BorderBrush="Gray" BorderThickness="1" Padding="6">
      <Grid ColumnDefinitions="60,140,8,80,8,*" RowDefinitions="Auto,Auto">
        <TextBlock Grid.Row="0" Grid.Column="0" Text="Item ID:" VerticalAlignment="Center" />
        <TextBox   Grid.Row="0" Grid.Column="1" x:Name="c_ItemIdBox" />
        <Button    Grid.Row="0" Grid.Column="3" x:Name="c_BrowseBtn" Content="Browse..." Click="OnBrowse" />
        <Button    Grid.Row="0" Grid.Column="5" x:Name="c_LoadBtn"   Content="Load"      Click="OnLoad" />
        <TextBlock Grid.Row="1" Grid.Column="0" Text="Name:" VerticalAlignment="Center" Margin="0,4,0,0" />
        <TextBlock Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="5" x:Name="c_ItemName"
                   VerticalAlignment="Center" Margin="0,4,0,0" Foreground="DimGray" />
      </Grid>
    </HeaderedContentControl>

    <HeaderedContentControl x:Name="c_EffectsGroup" Header="Effects (up to 5)"
                            BorderBrush="Gray" BorderThickness="1" Padding="6">
      <StackPanel x:Name="c_EffectStack" Spacing="4" />
    </HeaderedContentControl>

    <HeaderedContentControl Header="Container (Activatable)"
                            BorderBrush="Gray" BorderThickness="1" Padding="6">
      <Grid ColumnDefinitions="120,140,12,120,140,12,120,140" RowDefinitions="Auto">
        <TextBlock Grid.Column="0" Text="Recharge Time (ms):" VerticalAlignment="Center" />
        <TextBox   Grid.Column="1" x:Name="c_CoolDown" />
        <TextBlock Grid.Column="3" Text="Energy Use:" VerticalAlignment="Center" />
        <TextBox   Grid.Column="4" x:Name="c_EnergyUse" />
        <TextBlock Grid.Column="6" Text="Range:" VerticalAlignment="Center" />
        <TextBox   Grid.Column="7" x:Name="c_Range" />
      </Grid>
    </HeaderedContentControl>

    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
      <Button x:Name="c_SaveBtn"  Width="100" Content="Save"  Click="OnSave" />
      <Button x:Name="c_CloseBtn" Width="100" Content="Close" Click="OnClose" />
    </StackPanel>
    <TextBlock x:Name="c_Status" Foreground="DimGray" />
  </StackPanel>
  </ScrollViewer>
</Window>
