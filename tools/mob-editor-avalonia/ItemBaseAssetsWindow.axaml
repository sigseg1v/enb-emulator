<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="MobEditorAvalonia.ItemBaseAssetsWindow"
        Width="560" Height="540"
        Title="Choose Item Base Asset"
        WindowStartupLocation="CenterOwner">
  <DockPanel Margin="8">
    <Grid DockPanel.Dock="Top" ColumnDefinitions="Auto,*,8,Auto,Auto" RowDefinitions="Auto">
      <TextBlock Grid.Column="0" Text="Category:" VerticalAlignment="Center" Margin="0,0,6,0" />
      <ComboBox Grid.Column="1" Name="c_Category"
                SelectionChanged="OnCategoryChanged" />
      <TextBlock Grid.Column="3" Text="Level:" VerticalAlignment="Center" Margin="0,0,6,0" />
      <ComboBox Grid.Column="4" Name="c_LevelFilter" Width="90"
                SelectionChanged="OnLevelChanged" />
    </Grid>

    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                HorizontalAlignment="Right" Margin="0,8,0,0" Spacing="8">
      <Button Content="Add" Width="80" Click="OnAddClick" IsDefault="True" />
      <Button Content="Cancel" Width="80" Click="OnCancelClick" IsCancel="True" />
    </StackPanel>

    <Border Margin="0,6,0,0" BorderBrush="Gray" BorderThickness="1">
      <ListBox Name="c_ItemList" />
    </Border>
  </DockPanel>
</Window>
