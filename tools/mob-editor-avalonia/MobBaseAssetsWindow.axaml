<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="MobEditorAvalonia.MobBaseAssetsWindow"
        Width="500" Height="500"
        Title="Choose Mob Base Asset"
        WindowStartupLocation="CenterOwner">
  <DockPanel Margin="8">
    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="6">
      <TextBlock Text="Category:" VerticalAlignment="Center" />
      <ComboBox Name="c_Category" Width="280"
                SelectionChanged="OnCategoryChanged" />
    </StackPanel>

    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                HorizontalAlignment="Right" Margin="0,8,0,0" Spacing="8">
      <Button Content="Select" Width="80" Click="OnSelectClick" IsDefault="True" />
      <Button Content="Cancel" Width="80" Click="OnCancelClick" IsCancel="True" />
    </StackPanel>

    <Border Margin="0,6,0,0" BorderBrush="Gray" BorderThickness="1">
      <ListBox Name="c_AssetList" />
    </Border>
  </DockPanel>
</Window>
