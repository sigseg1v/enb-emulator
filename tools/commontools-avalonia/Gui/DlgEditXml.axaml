<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="CommonTools.Gui.DlgEditXml"
        Title="Edit XML"
        Width="600" Height="450"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="10" RowDefinitions="*,Auto">
        <TextBox Grid.Row="0" x:Name="guiXmlTxt"
                 AcceptsReturn="True" AcceptsTab="True" TextWrapping="Wrap"
                 FontFamily="Monospace"
                 VerticalContentAlignment="Top"
                 HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="guiCancelBtn" Content="Cancel" Width="90" Margin="0,0,8,0"/>
            <Button x:Name="guiOkBtn"     Content="OK"     Width="90" IsEnabled="False"/>
        </StackPanel>
    </Grid>
</Window>
