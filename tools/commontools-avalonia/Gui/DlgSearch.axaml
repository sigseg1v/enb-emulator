<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="CommonTools.Gui.DlgSearch"
        Title="Search"
        Width="640" Height="500"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="10" RowDefinitions="Auto,Auto,Auto,*,Auto,Auto">
        <TextBlock Grid.Row="0" Text="Search criteria" Margin="0,0,0,4"/>

        <ListBox Grid.Row="1" x:Name="guiSearchCriteriaTbl" Height="100" Margin="0,0,0,4"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,8">
            <Button x:Name="guiAddBtn"    Content="Add"    Width="80" Margin="0,0,4,0"/>
            <Button x:Name="guiEditBtn"   Content="Edit"   Width="80" Margin="0,0,4,0"/>
            <Button x:Name="guiRemoveBtn" Content="Remove" Width="80" Margin="0,0,16,0"/>
            <Button x:Name="guiSearchBtn" Content="Search" Width="100"/>
        </StackPanel>

        <DataGrid Grid.Row="3" x:Name="guiResultTbl"
                  AutoGenerateColumns="False"
                  CanUserSortColumns="True"
                  CanUserReorderColumns="True"
                  CanUserResizeColumns="True"
                  GridLinesVisibility="All"
                  HeadersVisibility="Column"
                  IsReadOnly="True"
                  SelectionMode="Single"/>

        <TextBlock Grid.Row="4" x:Name="guiResultLbl" Margin="0,6,0,0"/>

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button x:Name="guiOkBtn"     Content="OK"     Width="80" Margin="0,0,8,0"/>
            <Button x:Name="guiCancelBtn" Content="Cancel" Width="80"/>
        </StackPanel>
    </Grid>
</Window>
