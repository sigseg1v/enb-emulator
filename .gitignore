cmake_install.cmake
install_manifest.txt
build/
out/
cmake-build-*/
.ninja_*
compile_commands.json

# .NET / C#
bin/
obj/
*.user
*.suo
*.userprefs
*.usertasks
.vs/
*.cache
*.psess
*.vspx
*.pidb
*.svclog
packages/
TestResults/
