# IDEs / editors
.idea/
.vscode/
*.swp
*.swo
*~

# OS junk
.DS_Store
Thumbs.db

# SVN remnants
.svn/

# Local dev env
.env
.env.local
*.local
.direnv/

# Postgres dev data dir from docker-compose
pgdata/

# Logs
*.log

# ----- Re-includes (`!` rules) for kept files that the patterns above would otherwise eat -----

# Vendor binaries we don't have source for — see THIRD_PARTY_BINARIES.md notes
!vendor/**

# Third-party libs vendored with the server build (we may keep some prebuilt artefacts)
!server/third_party/**

# C# tool resources (icons, images, sprites) often live under bin/ or with .dll extension
!tools/**/Resources/**
!tools/**/Images/**
!tools/**/Sprites/**

# Game-asset binaries from kyp's tooling
!archive/kyp-snapshot/**

# Original packet captures
!**/capturedPackets/**

# Reference docs (rtf, pdf)
!**/*.rtf
!**/*.pdf
